; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="game dev diciplines & technology"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[dotnet]

project/assembly_name="game dev diciplines & technology"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_rl_agents/plugin.cfg", "res://addons/rider-plugin/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "yellow",
"res://script_templates/": "gray",
"res://scripts/": "gray",
"res://sync/": "gray"
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
